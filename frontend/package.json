{
  "name": "pandapower-viz",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/pandapower-viz.cjs",
  "module": "./dist/pandapower-viz.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pandapower-viz.js",
      "require": "./dist/pandapower-viz.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": ["*.css"],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "vis-network": "^9.1.9",
    "vis-data": "^7.1.9",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/leaflet": "^1.9.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "@vitejs/plugin-react": "^4.3.3",
    "vitest": "^2.1.8",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "jsdom": "^25.0.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-lib": "vite build --mode lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
